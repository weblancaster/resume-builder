---
import Layout from '../layouts/Layout.astro';
import { defaultResume } from '../data/resume';

const r = defaultResume;
---
<Layout title="Resume Builder">
  <!-- Toolbar -->
  <div class="toolbar">
    <button id="btn-print">🖨️ Print / Save PDF</button>
  </div>

  <div class="resume-wrapper">
    <div class="resume-container">

      <!-- Header -->
      <header class="resume-header">
        <div class="resume-header-left">
          <h1 class="resume-name">{r.name}</h1>
          <p class="resume-title">{r.title}</p>
        </div>
        <div class="resume-header-right">
          <span>{r.phone}</span>
          <span>{r.email}</span>
          <span>{r.website}</span>
          <span>{r.location}</span>
        </div>
      </header>

      <!-- Main column -->
      <main class="resume-main">

        <!-- Experience -->
        <section class="section">
          <h2 class="section-label">Experience</h2>
          {r.experiences.map((exp) => (
            <div class="exp-item">
              <div class="exp-header">
                <span class="exp-title">{exp.title}</span>
                <span class="exp-period">{exp.period}</span>
              </div>
              <div class="exp-company">
                {exp.companyUrl
                  ? <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer">{exp.company}</a>
                  : exp.company
                }
              </div>
              <div class="exp-description">{exp.description}</div>
            </div>
          ))}
        </section>

      </main>

      <!-- Sidebar -->
      <aside class="resume-sidebar">

        <!-- Skills -->
        <section class="section">
          <h2 class="section-label">Skills</h2>
          <div class="skills-group">
            <div class="skills-group-label">Proficient</div>
            <div class="skills-value">{r.skills.proficient.join(', ')}</div>
          </div>
          <div class="skills-group">
            <div class="skills-group-label">Familiar</div>
            <div class="skills-value">{r.skills.familiar.join(', ')}</div>
          </div>
        </section>

        <!-- Open Source -->
        <section class="section">
          <h2 class="section-label">Open Source</h2>
          {r.oss.map((item) => (
            <div class="list-item">
              <a href={item.url} target="_blank" rel="noopener noreferrer">{item.name}</a>
            </div>
          ))}
        </section>

        <!-- Talks -->
        <section class="section">
          <h2 class="section-label">Talks</h2>
          {r.talks.map((item) => (
            <div class="list-item">
              {item.url
                ? <a href={item.url} target="_blank" rel="noopener noreferrer">{item.name}</a>
                : item.name
              }
            </div>
          ))}
        </section>

        <!-- Education -->
        <section class="section">
          <h2 class="section-label">Education</h2>
          {r.education.map((edu) => (
            <div class="edu-item">
              <div class="edu-degree">{edu.degree}</div>
              <div class="edu-school">{edu.school}</div>
              <div class="edu-period">{edu.period}</div>
              <div class="edu-description">{edu.description}</div>
            </div>
          ))}
        </section>

      </aside>

    </div>
  </div>

  <script>
    document.getElementById('btn-print')?.addEventListener('click', async () => {
      const btn = document.getElementById('btn-print') as HTMLButtonElement;
      if (!btn) return;

      btn.disabled = true;
      btn.textContent = '⏳ Preparing…';

      try {
        await new Promise<void>(resolve => requestAnimationFrame(() => resolve()));
        window.print();
      } finally {
        btn.disabled = false;
        btn.textContent = '🖨️ Print / Save PDF';
      }
    });
  </script>
</Layout>
