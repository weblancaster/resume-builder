---
import Layout from '../layouts/Layout.astro';
import { defaultResume } from '../data/resume';

const r = defaultResume;
---
<Layout title="Resume Builder">
  <!-- Toolbar -->
  <div class="toolbar">
    <button id="btn-edit">✏️ Edit</button>
    <button id="btn-print">🖨️ Print</button>
  </div>

  <div class="resume-wrapper">
    <div class="resume-container">

      <!-- Header -->
      <header class="resume-header">
        <div class="resume-header-left">
          <h1 class="resume-name" data-field="name">{r.name}</h1>
          <p class="resume-title" data-field="title">{r.title}</p>
        </div>
        <div class="resume-header-right">
          <span data-field="phone">{r.phone}</span>
          <span data-field="email">{r.email}</span>
          <span data-field="website">{r.website}</span>
          <span data-field="location">{r.location}</span>
        </div>
      </header>

      <!-- Main column -->
      <main class="resume-main">

        <!-- Experience -->
        <section class="section">
          <h2 class="section-label">Experience</h2>
          {r.experiences.map((exp, i) => (
            <div class="exp-item">
              <div class="exp-header">
                <span class="exp-title" data-field={`exp-${i}-title`}>{exp.title}</span>
                <span class="exp-period" data-field={`exp-${i}-period`}>{exp.period}</span>
              </div>
              <div class="exp-company" data-field={`exp-${i}-company`}>
                {exp.companyUrl
                  ? <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer">{exp.company}</a>
                  : exp.company
                }
              </div>
              <div class="exp-description" data-field={`exp-${i}-description`}>{exp.description}</div>
            </div>
          ))}
        </section>

      </main>

      <!-- Sidebar -->
      <aside class="resume-sidebar">

        <!-- Skills -->
        <section class="section">
          <h2 class="section-label">Skills</h2>
          <div class="skills-group">
            <div class="skills-group-label">Proficient</div>
            <div class="skills-value" data-field="skills-proficient">{r.skills.proficient.join(', ')}</div>
          </div>
          <div class="skills-group">
            <div class="skills-group-label">Familiar</div>
            <div class="skills-value" data-field="skills-familiar">{r.skills.familiar.join(', ')}</div>
          </div>
        </section>

        <!-- Open Source -->
        <section class="section">
          <h2 class="section-label">Open Source</h2>
          {r.oss.map((item, i) => (
            <div class="list-item" data-field={`oss-${i}`}>{item}</div>
          ))}
        </section>

        <!-- Talks -->
        <section class="section">
          <h2 class="section-label">Talks</h2>
          {r.talks.map((item, i) => (
            <div class="list-item" data-field={`talk-${i}`}>{item}</div>
          ))}
        </section>

        <!-- Education -->
        <section class="section">
          <h2 class="section-label">Education</h2>
          {r.education.map((edu, i) => (
            <div class="edu-item">
              <div class="edu-degree" data-field={`edu-${i}-degree`}>{edu.degree}</div>
              <div class="edu-school" data-field={`edu-${i}-school`}>{edu.school}</div>
              <div class="edu-period" data-field={`edu-${i}-period`}>{edu.period}</div>
              <div class="edu-description" data-field={`edu-${i}-description`}>{edu.description}</div>
            </div>
          ))}
        </section>

      </aside>

    </div>
  </div>

  <script>
    import { load, save } from '../scripts/storage';
    import { toggleEdit } from '../scripts/editor';

    // Helpers
    const getField = (field: string): string =>
      document.querySelector<HTMLElement>(`[data-field="${field}"]`)?.textContent ?? '';

    const setField = (field: string, value: string): void => {
      const el = document.querySelector<HTMLElement>(`[data-field="${field}"]`);
      if (el) el.textContent = value;
    };

    const parseList = (text: string | null | undefined): string[] =>
      text?.split(',').map(s => s.trim()).filter(Boolean) ?? [];

    const readListFields = (prefix: string, count: number): string[] =>
      Array.from({ length: count }, (_, i) => getField(`${prefix}-${i}`));

    // Debounce helper to batch rapid blur events into a single save
    let saveTimer: ReturnType<typeof setTimeout> | undefined;
    const debouncedSave = (): void => {
      clearTimeout(saveTimer);
      saveTimer = setTimeout(persistAll, 300);
    };

    const persistAll = (): void => {
      const current = load();

      // Simple string fields
      (['name', 'title', 'phone', 'email', 'website', 'location', 'summary'] as const).forEach(field => {
        (current as Record<string, unknown>)[field] = getField(field);
      });

      // Experience
      current.experiences.forEach((exp, i) => {
        exp.title = getField(`exp-${i}-title`);
        exp.company = getField(`exp-${i}-company`);
        exp.period = getField(`exp-${i}-period`);
        exp.description = getField(`exp-${i}-description`);
      });

      // Education
      current.education.forEach((edu, i) => {
        edu.degree = getField(`edu-${i}-degree`);
        edu.school = getField(`edu-${i}-school`);
        edu.period = getField(`edu-${i}-period`);
      });

      // Skills
      current.skills.proficient = parseList(getField('skills-proficient'));
      current.skills.familiar = parseList(getField('skills-familiar'));

      // List sections
      current.oss = readListFields('oss', current.oss.length);
      current.talks = readListFields('talk', current.talks.length);

      save(current);
    };

    document.addEventListener('DOMContentLoaded', () => {
      const resume = load();

      // Populate simple fields
      setField('name', resume.name);
      setField('title', resume.title);
      setField('phone', resume.phone);
      setField('email', resume.email);
      setField('website', resume.website);
      setField('location', resume.location);

      // Populate experience fields
      resume.experiences.forEach((exp, i) => {
        setField(`exp-${i}-title`, exp.title);
        setField(`exp-${i}-company`, exp.company);
        setField(`exp-${i}-period`, exp.period);
        setField(`exp-${i}-description`, exp.description);
      });

      // Populate education fields
      resume.education.forEach((edu, i) => {
        setField(`edu-${i}-degree`, edu.degree);
        setField(`edu-${i}-school`, edu.school);
        setField(`edu-${i}-period`, edu.period);
      });

      // Populate skills
      setField('skills-proficient', resume.skills.proficient.join(', '));
      setField('skills-familiar', resume.skills.familiar.join(', '));

      // Populate OSS, talks
      resume.oss.forEach((item, i) => setField(`oss-${i}`, item));
      resume.talks.forEach((item, i) => setField(`talk-${i}`, item));

      // Save on blur (debounced)
      document.querySelectorAll('[data-field]').forEach(el => {
        el.addEventListener('blur', debouncedSave);
      });

      // Edit button
      document.getElementById('btn-edit')?.addEventListener('click', () => {
        const editing = toggleEdit();
        const btn = document.getElementById('btn-edit') as HTMLButtonElement;
        if (btn) btn.textContent = editing ? '✅ Done Editing' : '✏️ Edit';
      });

      // Print button
      document.getElementById('btn-print')?.addEventListener('click', () => {
        window.print();
      });
    });
  </script>
</Layout>
